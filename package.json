{
  "name": "smackums",
  "version": "0.1.1",
  "description": "A fun desktop toy: capture YouTube tab audio live, auto-detect key, chop into an 8-pad MIDI sampler.",
  "main": "./out/main/index.js",
  "author": "Jacob Felton",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dist": "electron-vite build && electron-builder --win portable"
  },
  "dependencies": {
    "soundtouchjs": "^0.2.1"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.dqlabs.smackums",
    "productName": "smackums",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false
    }
  }
}
